
# J Claw core identity
ASSISTANT_NAME=JClaw
ASSISTANT_HAS_OWN_NUMBER=false

# Container runtime
CONTAINER_IMAGE=jclaw-agent:latest
MAX_CONCURRENT_CONTAINERS=3

# Preferred local-model endpoint aliases.
# Point these at an Anthropic-compatible proxy such as LiteLLM if your model
# server only speaks OpenAI format (for example KoboldCPP).
JCLAW_GATEWAY_BASE_URL=http://127.0.0.1:4000
JCLAW_GATEWAY_AUTH_TOKEN=dummy-key
LOCAL_MODEL_BASE_URL=http://127.0.0.1:4000
LOCAL_MODEL_AUTH_TOKEN=dummy-key
JCLAW_MODEL=jclaw-main
JCLAW_WORKER_MODEL=jclaw-worker
JCLAW_USE_WORKER_MODEL_FOR_SCHEDULED=true
# JCLAW_FALLBACK_MODEL=claude-3-5-sonnet-latest

# Direct Anthropic-compatible endpoint variables still work and take precedence.
# ANTHROPIC_BASE_URL=http://127.0.0.1:4000
# ANTHROPIC_AUTH_TOKEN=dummy-key

# Multi-provider smart routing (openclaude-style health-aware routing).
# Strategy: latency (fastest), cost (cheapest), balanced (latency × cost, default).
# Local providers are scored with JCLAW_LOCAL_COST weight (default 0.01 = near-free).
# Unhealthy providers back off 60s before retrying.
JCLAW_ROUTER_STRATEGY=balanced
JCLAW_LOCAL_COST=0.01

# ── Provider: llama.cpp server ──────────────────────────────────────
# Point at your local llama.cpp server (OpenAI-compatible endpoint)
# LLAMACPP_BASE_URL=http://127.0.0.1:8080/v1
# LLAMACPP_API_KEY=           # optional, leave empty for local

# ── Provider: Ollama ────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# BIG_MODEL=gemma4:26b         # model used for complex tasks
# SMALL_MODEL=qwen3:3b          # model used for simple/quick tasks

# ── Provider: OpenRouter ────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # optional, this is the default

# ── Provider: OpenCode Zen ──────────────────────────────────────────
# OPENCODE_API_KEY=oc-...
# OPENCODE_BASE_URL=https://api.opencode.ai/v1       # optional, this is the default

# Optional host browser paths for real local browser automation.
# JCLAW_CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# JCLAW_FIREFOX_PATH=C:\Program Files\Mozilla Firefox\firefox.exe
# JCLAW_OPERA_PATH=C:\Users\<you>\AppData\Local\Programs\Opera\opera.exe
# JCLAW_HOST_BROWSER_HEADLESS=false
# JCLAW_HOST_BROWSER_IDLE_MS=300000

# Increase if your local model is slow on longer tasks.
CONTAINER_TIMEOUT=3600000
IDLE_TIMEOUT=3600000

